let NeuralNetwork input =
    let a1 = RELU (input*W1+b1) in
    let a2 = RELU (a1*W2+b2) in
    let a3 = RELU (a2*W3+b3) in
    ARGMAX a3
;
//wtime (NeuralNetwork input);


