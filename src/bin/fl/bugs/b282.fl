// ==================================================================
// Example 2: Neural network
let RELU vec =
    val (SMAT rows cols ridx cidx v) = vec in
    let v' = ((v >= '0) => v | '0) in
    (SMAT rows cols ridx cidx v')
;

let NORMALIZE vec =
    val (SMAT rows cols ridx cidx v) = vec in
    let total = sum (depends (ridx,cidx)) v in
    let v' = ('1024 * v)/total in
    (SMAT rows cols ridx cidx v')
;

// Compute maximum value of (positive) bv
let bv_max bv =
    letrec try bits =
	bits = [] => [] |
	val (b:bs) = bits in
	b == F => F:(try bs) |
	let sub = param b in
	T:(try (substitute sub bs))
    in
    list2bv (try (bv2list bv))
;

let ARGMAX vec =
    val (SMAT rows cols ridx cidx v) = vec in
    let max = bv_max v in
    let res = (max = v => '1 | '0) in
    (SMAT rows cols ridx cidx res)
;

