//let m9 = RELU m8; wtime (sm_size m9);
//let m10 = ARGMAX m9; wtime (sm_size m10);


let tst0 = mk_random_svectr 784 0 31;
let tst1 = mk_random_svectr 784 0 31;
let tst2 = mk_random_svectr 784 0 31;
let tst3 = mk_random_svectr 784 0 31;
let tst4 = mk_random_svectr 784 0 31;
let tst5 = mk_random_svectr 784 0 31;
let tst6 = mk_random_svectr 784 0 31;
let tst7 = mk_random_svectr 784 0 31;


wtime (tst0 fseq tst1 fseq tst2 fseq tst3 fseq tst4 fseq tst5 fseq tst6 fseq tst7 fseq ());

let res0 = NeuralNetwork tst0;
let res1 = NeuralNetwork tst1;
let res2 = NeuralNetwork tst2;
let res3 = NeuralNetwork tst3;
let res4 = NeuralNetwork tst4;
let res5 = NeuralNetwork tst5;
let res6 = NeuralNetwork tst6;
let res7 = NeuralNetwork tst7;

var_order ["r[10]","mid[10]","c[10]","r[9:8,5:4,7:6]","mid[9:1]","q[1:2,0]","c[9:7]","mid[0]","c[6:4]","r[3:2]","c[3]","r[1:0]","c[1:0,2]"];

//var_order ["r[10]","mid[10]","c[10]","mid[9:0]","q[2]","r[9:7]","q[1:0]","r[6:4]","c[9:7,5:6,4:3,1:0]","r[3,0,2:1]","c[2]"];



//wtime (res0 fseq res1 fseq res2 fseq res3 fseq res4 fseq res5 fseq res6 fseq res7 fseq ());	// 122.7 seconds

let ch = bv_uvector "q" 3;
ch;

var_order ["q[2]", "q[1]", "q[0]"];
//update_vossrc "DYNAMIC-ORDERING" "YES";

let tst = ch = '0 => tst0 |
	  ch = '1 => tst1 |
	  ch = '2 => tst2 |
	  ch = '3 => tst3 |
	  ch = '4 => tst4 |
	  ch = '5 => tst5 |
	  ch = '6 => tst6 |
	  tst7
;

let res = NeuralNetwork tst;
time res;   // 94.6 seconds

